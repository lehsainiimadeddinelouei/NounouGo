rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() { return request.auth != null; }
    function isOwner(uid) { return request.auth.uid == uid; }
    function isAdmin() {
      return request.auth.token.email == 'lehsainiimadeddinelouei@gmail.com';
    }

    match /users/{uid} {
      allow read: if isAuth();
      allow write: if isAdmin();
      allow write: if isAuth() && isOwner(uid);
      allow update: if isAuth() &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['score', 'nbAvis']);
    }

    // ── Comptes supprimés par l'admin ──
    // L'admin peut lire/écrire/supprimer
    // Tout utilisateur connecté peut lire (pour vérif à l'inscription)
    match /deleted_accounts/{uid} {
      allow read: if isAuth();
      allow write, delete: if isAdmin();
    }

    match /otp_codes/{uid} {
      allow read, write: if isAuth() && isOwner(uid);
    }

    match /demandes/{demandeId} {
      allow read, write: if isAdmin();
      allow read: if isAuth() &&
        (resource.data.parentUid == request.auth.uid ||
         resource.data.nounouUid == request.auth.uid);
      allow create: if isAuth() &&
        request.resource.data.parentUid == request.auth.uid;
      allow update: if isAuth() && (
        (resource.data.nounouUid == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['statut', 'prixHeure'])) ||
        (resource.data.parentUid == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['paiementStatut','paiementMethode','paiementId','paiementMontant','evaluee']))
      );
      allow delete: if isAuth() &&
        (resource.data.parentUid == request.auth.uid ||
         resource.data.nounouUid == request.auth.uid);
    }

    match /notifications/{notifId} {
      allow read, write: if isAdmin();
      allow read: if isAuth() &&
        resource.data.destinataireUid == request.auth.uid;
      allow create: if isAuth();
      allow update, delete: if isAuth() &&
        resource.data.destinataireUid == request.auth.uid;
    }

    match /conversations/{convId} {
      allow read, write: if isAuth();
      match /messages/{msgId} {
        allow read, write: if isAuth();
      }
    }

    match /paiements/{paiementId} {
      allow read, write: if isAdmin();
      allow read: if isAuth() && (
        resource.data.parentUid == request.auth.uid ||
        resource.data.nounouUid == request.auth.uid
      );
      allow create: if isAuth() &&
        request.resource.data.payeurUid == request.auth.uid;
      allow delete: if isAuth() && (
        resource.data.parentUid == request.auth.uid ||
        resource.data.nounouUid == request.auth.uid
      );
    }

    match /avis/{avisId} {
      allow read, write: if isAdmin();
      allow read: if isAuth();
      allow create: if isAuth() &&
        request.resource.data.parentUid == request.auth.uid;
      allow delete: if isAuth() &&
        resource.data.parentUid == request.auth.uid;
    }
  }
}
