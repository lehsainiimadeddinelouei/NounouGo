rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() { return request.auth != null; }
    function isOwner(uid) { return request.auth.uid == uid; }

    match /users/{uid} {
      allow read: if isAuth();
      allow write: if isAuth() && isOwner(uid);
    }

    match /otp_codes/{uid} {
      allow read, write: if isAuth() && isOwner(uid);
    }

    match /demandes/{demandeId} {
      allow read: if isAuth() &&
        (resource.data.parentUid == request.auth.uid ||
         resource.data.nounouUid == request.auth.uid);
      allow create: if isAuth() &&
        request.resource.data.parentUid == request.auth.uid;
      allow update: if isAuth() && (
        (resource.data.nounouUid == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['statut', 'prixHeure'])) ||
        (resource.data.parentUid == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['paiementStatut','paiementMethode','paiementId','paiementMontant','evaluee']))
      );
      allow delete: if isAuth() &&
        (resource.data.parentUid == request.auth.uid ||
         resource.data.nounouUid == request.auth.uid);
    }

    match /notifications/{notifId} {
      allow read: if isAuth() &&
        resource.data.destinataireUid == request.auth.uid;
      allow create: if isAuth();
      allow update: if isAuth() &&
        resource.data.destinataireUid == request.auth.uid;
      allow delete: if isAuth() &&
        resource.data.destinataireUid == request.auth.uid;
    }

    match /conversations/{convId} {
      allow read, write: if isAuth() &&
        (resource == null || request.auth.uid in resource.data.participants);
      allow create: if isAuth() &&
        request.auth.uid in request.resource.data.participants;

      match /messages/{msgId} {
        // Lecture et suppression: si authentifié et impliqué dans la conv
        allow read, delete: if isAuth() && (
          resource == null ||
          resource.data.senderUid == request.auth.uid ||
          resource.data.receiverUid == request.auth.uid
        );
        allow create: if isAuth() &&
          request.resource.data.senderUid == request.auth.uid;
        allow update: if isAuth() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lu']);
      }
    }

    match /paiements/{paiementId} {
      allow read: if isAuth() && (
        resource.data.parentUid == request.auth.uid ||
        resource.data.nounouUid == request.auth.uid
      );
      allow create: if isAuth() &&
        request.resource.data.payeurUid == request.auth.uid;
      allow update: if false;
      allow delete: if isAuth() && (
        resource.data.parentUid == request.auth.uid ||
        resource.data.nounouUid == request.auth.uid
      );
    }

    match /avis/{avisId} {
      allow read: if isAuth();
      allow create: if isAuth() &&
        request.resource.data.parentUid == request.auth.uid;
      allow update: if false;
      allow delete: if isAuth() &&
        resource.data.parentUid == request.auth.uid;
    }
  }
}
