rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() { return request.auth != null; }
    function isOwner(uid) { return request.auth.uid == uid; }
    function isAdmin() {
      return request.auth.token.email == 'lehsainiimadeddinelouei@gmail.com';
    }

    match /users/{uid} {
      // Tout utilisateur connecté peut lire les profils (pour chercher des nounous)
      allow read: if isAuth();
      // Admin peut tout faire
      allow write: if isAdmin();
      // Propriétaire peut modifier son propre profil
      allow write: if isAuth() && isOwner(uid);
      // N'importe qui peut mettre à jour score et nbAvis
      allow update: if isAuth() &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['score', 'nbAvis']);
    }

    match /otp_codes/{uid} {
      allow read, write: if isAuth() && isOwner(uid);
    }

    match /demandes/{demandeId} {
      allow read, write: if isAdmin();
      allow read: if isAuth() &&
        (resource.data.parentUid == request.auth.uid ||
         resource.data.nounouUid == request.auth.uid);
      allow create: if isAuth() &&
        request.resource.data.parentUid == request.auth.uid;
      allow update: if isAuth() && (
        (resource.data.nounouUid == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['statut', 'prixHeure'])) ||
        (resource.data.parentUid == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['paiementStatut','paiementMethode','paiementId','paiementMontant','evaluee']))
      );
      allow delete: if isAuth() &&
        (resource.data.parentUid == request.auth.uid ||
         resource.data.nounouUid == request.auth.uid);
    }

    match /notifications/{notifId} {
      allow read, write: if isAdmin();
      allow read: if isAuth() &&
        resource.data.destinataireUid == request.auth.uid;
      allow create: if isAuth();
      allow update, delete: if isAuth() &&
        resource.data.destinataireUid == request.auth.uid;
    }

    match /conversations/{convId} {
      allow read, write: if isAuth();
      match /messages/{msgId} {
        allow read, write: if isAuth();
      }
    }

    match /paiements/{paiementId} {
      allow read, write: if isAdmin();
      allow read: if isAuth() && (
        resource.data.parentUid == request.auth.uid ||
        resource.data.nounouUid == request.auth.uid
      );
      allow create: if isAuth() &&
        request.resource.data.payeurUid == request.auth.uid;
      allow delete: if isAuth() && (
        resource.data.parentUid == request.auth.uid ||
        resource.data.nounouUid == request.auth.uid
      );
    }

    match /avis/{avisId} {
      allow read, write: if isAdmin();
      allow read: if isAuth();
      allow create: if isAuth() &&
        request.resource.data.parentUid == request.auth.uid;
      allow delete: if isAuth() &&
        resource.data.parentUid == request.auth.uid;
    }

    // ── Documents uploadés par les nounous ──
    // Les documents (PDF base64) sont stockés dans users/{uid}
    // donc déjà couverts par la règle users ci-dessus.
    // La nounou voit ses propres docs via isOwner(uid)
    // L'admin voit tous les docs via isAdmin()
    // Le parent voit les infos publiques via read: isAuth()
    // Les champs sensibles (base64 PDF) sont accessibles car read est ouvert aux auth
  }
}
