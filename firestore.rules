rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() { return request.auth != null; }

    function isAdmin() {
      return isAuth() && (
        request.auth.token.email == 'lehsainiimadeddinelouei@gmail.com' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function isOwner(uid) { return isAuth() && request.auth.uid == uid; }

    match /users/{uid} {
      allow read: if isAuth();
      allow create: if isAuth() && request.auth.uid == uid;
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isOwner(uid) || isAdmin(); // ← nounou peut supprimer son propre compte

      match /documents/{docId} {
        allow read: if isOwner(uid) || isAdmin();
        allow write: if isOwner(uid) || isAdmin();
        allow delete: if isOwner(uid) || isAdmin(); // ← peut supprimer ses propres docs
      }
    }

    match /deleted_accounts/{docId} {
      allow read: if isAuth();
      allow write: if isAuth(); // ← tout utilisateur connecté peut s'y enregistrer
      allow delete: if isAdmin();
    }

    match /conversations/{convId} {
      allow read, write: if isAuth() &&
        (resource == null || request.auth.uid in resource.data.participants);
    }

    match /conversations/{convId}/messages/{msgId} {
      allow read, write: if isAuth();
    }

    match /notifications/{uid}/items/{notifId} {
      allow read: if isOwner(uid);
      allow write: if isAuth();
    }
  }
}
